{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:base"
  ],
  "packageRules": [
    {
      "groupName": "Kotlin and Compose Multiplatform",
      "groupSlug": "kotlin",
      "matchPackageNames": [
        "org.jetbrains.kotlin",
        "org.jetbrains.compose"
      ]
    },
    {
      "description": "Disable updates to SNAPSHOTS",
      "matchDatasources": ["maven"],
      "allowedVersions": "!/SNAPSHOT$/"
    },
    {
      "description": "Avoid kotlinx-datetime -compat variant (renovate sorts it above plain releases)",
      "matchPackageNames": ["org.jetbrains.kotlinx:kotlinx-datetime"],
      "allowedVersions": "!/-compat$/"
    }
  ]
}